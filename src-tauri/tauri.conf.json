{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ID Maker",
  "version": "0.1.0",
  "identifier": "com.local.id-maker",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ID Maker",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
